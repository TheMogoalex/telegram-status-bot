# Telegram delivery. Required for normal mode. Not required for --dry-run.
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Report identity.
SERVER_NAME=my-linux-server
REPORT_LANGUAGE=en

# Comma-separated absolute paths shown in the report.
DISK_PARTITIONS=/,/data

# Alerts. Set a threshold to 0 to disable that alert.
DISK_USAGE_ALERT_PERCENT=80
RAM_USAGE_ALERT_PERCENT=85
CPU_TEMPERATURE_ALERT_CELSIUS=75
MIN_UPTIME_ALERT_MINUTES=10

# Docker host metrics support. Keep defaults for local Python execution.
HOST_ROOT=/
HOST_PROC=/proc
HOST_SYS=/sys

# Optional explicit CPU temperature file, for example:
# CPU_TEMPERATURE_PATH=/sys/class/thermal/thermal_zone0/temp
CPU_TEMPERATURE_PATH=

# Telegram HTTP timeout.
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
